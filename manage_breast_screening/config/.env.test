# Avoid django.core.exceptions.SynchronousOnlyOperation from playwright fixtures.
# Playwright seems to use an event loop even when in synchronous mode, which
# causes Django to assume we are calling its database functions from async code.
# https://docs.djangoproject.com/en/6.0/topics/async/#envvar-DJANGO_ALLOW_ASYNC_UNSAFE
DJANGO_ALLOW_ASYNC_UNSAFE=true
