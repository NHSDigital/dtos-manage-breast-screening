{% from "nhsuk/components/button/macro.jinja" import button %}
{% from "nhsuk/components/tag/macro.jinja" import tag %}
{% from "nhsuk/macros/attributes.jinja" import nhsukAttributes %}
{% from "components/image-key-item/macro.jinja" import app_image_key_item %}
{% from "components/image-marker/macro.jinja" import app_image_marker %}

{#- Set classes for this component #}
{%- set classNames = "app-image-key" -%}

{%- if params.classes %}
  {% set classNames = classNames ~ " " ~ params.classes %}
{% endif %}

{% set items = params["items"] if "items" in params else [] %}

<div {{- nhsukAttributes({
  "class": classNames,
  "data-module": "app-image-key",
  "data-read-only": {
    "value": "true" if params.read_only else false,
    "optional": true
  },
  "hidden": {
    "value": true if not items | length else false,
    "optional": true
  }
}) -}}>
  <div class="app-image-key__header">
    <h3 class="app-image-key__title">Key</h3>
  {% if not params.read_only %}
    <button class="app-button app-button--link app-link--warning app-image-key__button" hidden>
      Clear all features
    </button>
  {% endif %}
  </div>

  <template class="app-js-template-image-key-item">
    {{ app_image_key_item({
      "index": "?",
      "feature": "Pending",
      "region": "Unknown",
      "href": "#" if not params.read_only else undefined
    }) | trim | indent(4) }}
  </template>

  <ul class="app-image-key__items">
  {% for item in items %}
    {{ app_image_key_item({
      "index": loop.index,
      "feature": item.id | replace("_", " ") | capitalize,
      "region": item.region_id | replace("_", " ") | capitalize,
      "href": undefined if params.read_only else "#marker-" ~ loop.index
    }) | trim | indent(4) }}
  {% endfor %}
  </ul>
</div>
