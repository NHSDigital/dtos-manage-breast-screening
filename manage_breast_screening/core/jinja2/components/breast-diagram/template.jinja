{% from "nhsuk/macros/attributes.jinja" import nhsukAttributes -%}

<div {{- nhsukAttributes({
  "class": "app-breast-diagram",
  "data-module": "app-breast-diagram",
  "data-debug": {
    "value": "true" if params.debug else false,
    "optional": true
  },
  "data-read-only": {
    "value": "true" if params.read_only else false,
    "optional": true
  }
}) -}}>
  {% if caller or params.html %}
    {{ caller() if caller else params.html | safe | trim | indent(4) }}
  {% elif params.text %}
    <p class="nhsuk-body">
      {{ params.text | trim | indent(6) }}
    </p>
  {% endif %}

  <div class="app-breast-diagram__side-labels">
    <span>Right</span>
    <span>Left</span>
  </div>

  <figure
    {{- nhsukAttributes({
      "class": "app-breast-diagram__image-map nhsuk-u-width-full",
      "data-module": "app-image-map"
    }) -}}

    {{- nhsukAttributes(params.image_map.attributes) -}}>
  {% if params.version == 1 %}
    {% include "components/breast-diagram/v1.svg" %}
  {% endif %}
  </figure>

{% if params.debug %}
  {{ summaryList({
    "rows": [
      {
        "key": {
          "text": "Image X"
        },
        "value": {
          "text": "N/A",
          "classes": "app-js-image-x"
        }
      } if params.read_only else none,
      {
        "key": {
          "text": "Image Y"
        },
        "value": {
          "text": "N/A",
          "classes": "app-js-image-y"
        }
      } if params.read_only else none,
      {
        "key": {
          "text": "Image region"
        },
        "value": {
          "text": "N/A",
          "classes": "app-js-image-region"
        }
      } if params.read_only else none,
      {
        "key": {
          "text": "Input values"
        },
        "value": {
          "text": "N/A",
          "classes": "app-js-image-input"
        },
        "classes": "nhsuk-summary-list__row--no-border"
      }
    ]
  }) }}
{% endif %}
</div>
